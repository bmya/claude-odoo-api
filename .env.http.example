# HTTP transport — server-level configuration (NO Odoo credentials here)
#
# In HTTP mode the server stores no Odoo credentials: each user supplies their
# own instance via X-Odoo-* connection headers (see docs/remote-client-config.md).
# These variables tune the server itself and are read by docker-compose for
# variable substitution, or can be exported directly.

# Transport selector
MCP_TRANSPORT=http

# Bind address / port / mount path
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8080
MCP_HTTP_PATH=/mcp

# TLS: set BOTH to serve HTTPS directly (e.g. self-signed for local tests).
# Leave empty in production — TLS is terminated by the reverse proxy (Traefik),
# and the app runs plain HTTP behind it (it honours X-Forwarded-Proto).
MCP_TLS_CERTFILE=
MCP_TLS_KEYFILE=
# Client IPs trusted to set X-Forwarded-* ("*" = trust the fronting proxy).
MCP_FORWARDED_ALLOW_IPS=*

# Optional reconfigurable "front door": when set, requests must carry a matching
# X-Gateway-Token header. Leave empty to rely on the network gate (Twingate/VLAN).
MCP_GATEWAY_TOKEN=

# Server-level guardrails (apply to every user/connection)
ODOO_MCP_READONLY=
ODOO_MCP_ALLOWED_METHODS=
ODOO_REQUEST_TIMEOUT=30
ODOO_MAX_RETRIES=3
